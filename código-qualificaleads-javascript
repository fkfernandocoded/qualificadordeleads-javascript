function processAll() {
  setupSheets();

  let cycles = 0;
  let hasMore = true;

  while (hasMore && cycles < CONFIG.MAX_BATCH_CYCLES_PER_RUN) {
    hasMore = processNextBatch_();
    cycles++;
    Utilities.sleep(800);
  }
}

function processNextBatch() {
  setupSheets();
  processNextBatch_();
}

function processNextBatch_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sourceSheet = ss.getSheetByName(CONFIG.SOURCE_SHEET);
  const approvedSheet = ss.getSheetByName(CONFIG.APPROVED_SHEET);
  const reviewSheet = ss.getSheetByName(CONFIG.REVIEW_SHEET);

  if (!sourceSheet) {
    throw new Error(`A aba "${CONFIG.SOURCE_SHEET}" não foi encontrada.`);
  }

  const lastRow = sourceSheet.getLastRow();
  const lastCol = sourceSheet.getLastColumn();
  if (lastRow < 2) return false;

  const headers = sourceSheet.getRange(1, 1, 1, lastCol).getValues()[0].map(h => normalizeText_(String(h || '')));
  const cnpjCol = headers.indexOf('cnpj');
  if (cnpjCol === -1) {
    throw new Error('A aba Base_Cnpjs precisa ter uma coluna chamada CNPJ.');
  }

  const processed = getProcessedCnpjs_([approvedSheet, reviewSheet]);
  const props = PropertiesService.getScriptProperties();
  let cursor = Number(props.getProperty(CONFIG.SCRIPT_PROP_CURSOR) || 2);
  if (cursor < 2) cursor = 2;
  if (cursor > lastRow) cursor = 2;

  let done = 0;
  let row = cursor;

  while (row <= lastRow && done < CONFIG.BATCH_SIZE) {
    const rawCnpj = String(sourceSheet.getRange(row, cnpjCol + 1).getValue() || '').trim();
    const cnpj = normalizeCnpj_(rawCnpj);

    if (cnpj && !processed[cnpj]) {
      try {
        const result = processSingleLead_(rawCnpj, cnpj);

        if (result.destination === 'APPROVED') {
          appendOrUpdateApprovedRow_(approvedSheet, result);
          processed[cnpj] = true;
        } else if (result.destination === 'REVIEW') {
          appendOrUpdateReviewRow_(reviewSheet, result);
          processed[cnpj] = true;
        } else {
          logRow_(cnpj, 'REJEITADO', result.matchReason || 'Sem aderência');
          processed[cnpj] = true;
        }
      } catch (e) {
        logRow_(cnpj, 'ERRO', safeErrorMessage_(e));
      }

      done++;
      Utilities.sleep(CONFIG.REQUEST_DELAY_MS);
    }

    row++;
  }

  props.setProperty(CONFIG.SCRIPT_PROP_CURSOR, String(row));

  return row <= lastRow;
}

/************************************************************
 * PROCESSAMENTO DE UM LEAD
 ************************************************************/
function processSingleLead_(rawCnpj, cnpj) {
  const cnpjValido = isValidCnpj_(cnpj);

  if (!cnpjValido) {
    return {
      rawCnpj,
      cnpj,
      cnpjValido: false,
      destination: 'REJECT',
      matchReason: 'CNPJ inválido'
    };
  }

  const cnpjData = fetchCnpjBrasilApi_(cnpj);

  const preLead = {
    razaoSocial: cnpjData.razaoSocial || '',
    nomeFantasia: cnpjData.nomeFantasia || '',
    situacaoCadastral: cnpjData.situacaoCadastral || '',
    cnaePrincipal: cnpjData.cnaePrincipal || '',
    cnaesSecundarios: cnpjData.cnaesSecundarios || [],
    uf: cnpjData.uf || '',
    cidade: cnpjData.cidade || '',
    site: cnpjData.site || '',
    emails: cnpjData.email ? [cnpjData.email] : [],
    phones: cnpjData.telefone ? [cnpjData.telefone] : [],
    whatsapps: [],
    contatoNome: '',
    contatoTelefone: '',
    fonteContato: '',
    fonteCnpj: cnpjData.fonteCnpj || '',
    fontesSite: [],
    paginasAnalisadas: [],
    textBlob: [
      cnpjData.razaoSocial,
      cnpjData.nomeFantasia,
      cnpjData.cnaePrincipal,
      (cnpjData.cnaesSecundarios || []).join(' ')
    ].join(' ')
  };

  const preAnalysis = analyzeLeadFit_(preLead);

  const shouldInspectSite =
    !!preLead.site &&
    (
      preAnalysis.score >= 35 ||
      preAnalysis.strongKeywordCount >= 1 ||
      preAnalysis.cnaeStrong
    );

  let websiteData = emptyWebsiteData_();

  if (shouldInspectSite) {
    const siteCandidate = pickBestSite_(cnpjData);
    if (siteCandidate) {
      websiteData = inspectWebsite_(siteCandidate);
    }
  }

  const merged = mergeLeadData_(cnpjData, websiteData);
  const analysis = analyzeLeadFit_(merged);

  if (analysis.decision === 'APPROVED') {
    return {
      rawCnpj,
      cnpj,
      cnpjValido: true,
      destination: 'APPROVED',
      razaoSocial: merged.razaoSocial,
      nomeFantasia: merged.nomeFantasia,
      situacaoCadastral: merged.situacaoCadastral,
      cnaePrincipal: merged.cnaePrincipal,
      cnaesSecundarios: merged.cnaesSecundarios,
      uf: merged.uf,
      cidade: merged.cidade,
      site: merged.site,
      emails: merged.emails,
      phones: merged.phones,
      whatsapps: merged.whatsapps,
      contatoNome: merged.contatoNome,
      contatoTelefone: merged.contatoTelefone,
      matchType: analysis.matchType,
      matchScore: analysis.score,
      matchReason: analysis.reason,
      keywordsFound: analysis.keywordsFound,
      fonteCnpj: merged.fonteCnpj,
      fontesSite: merged.fontesSite,
      fonteContato: merged.fonteContato,
      paginasAnalisadas: merged.paginasAnalisadas
    };
  }

  if (analysis.decision === 'REVIEW') {
    return {
      rawCnpj,
      cnpj,
      cnpjValido: true,
      destination: 'REVIEW',
      razaoSocial: merged.razaoSocial,
      nomeFantasia: merged.nomeFantasia,
      situacaoCadastral: merged.situacaoCadastral,
      cnaePrincipal: merged.cnaePrincipal,
      cnaesSecundarios: merged.cnaesSecundarios,
      uf: merged.uf,
      cidade: merged.cidade,
      site: merged.site,
      emails: merged.emails,
      phones: merged.phones,
      whatsapps: merged.whatsapps,
      matchScore: analysis.score,
      reviewReason: analysis.reason,
      keywordsFound: analysis.keywordsFound,
      fonteCnpj: merged.fonteCnpj,
      fontesSite: merged.fontesSite,
      paginasAnalisadas: merged.paginasAnalisadas
    };
  }

  return {
    rawCnpj,
    cnpj,
    cnpjValido: true,
    destination: 'REJECT',
    matchReason: analysis.reason
  };
}

/************************************************************
 * FONTE CNPJ
 ************************************************************/
function fetchCnpjBrasilApi_(cnpj) {
  const url = CONFIG.BRASILAPI_CNPJ_URL + encodeURIComponent(cnpj);

  const res = UrlFetchApp.fetch(url, {
    method: 'get',
    muteHttpExceptions: true,
    followRedirects: true,
    headers: {
      'User-Agent': 'Mozilla/5.0',
      'Accept': 'application/json'
    }
  });

  const code = res.getResponseCode();

  if (code < 200 || code >= 300) {
    throw new Error(`Falha ao consultar CNPJ. HTTP ${code}`);
  }

  const json = JSON.parse(res.getContentText());

  return {
    cnpj: cnpj,
    razaoSocial: json.razao_social || json.nome || '',
    nomeFantasia: json.nome_fantasia || json.fantasia || '',
    situacaoCadastral: json.descricao_situacao_cadastral || json.situacao_cadastral || '',
    cnaePrincipal: mapMainCnae_(json),
    cnaesSecundarios: mapSecondaryCnaes_(json),
    uf: json.uf || '',
    cidade: json.municipio || json.cidade || '',
    site: extractSiteFromBrasilApi_(json),
    email: json.email || '',
    telefone: pickPhoneFromCnpjJson_(json),
    fonteCnpj: url
  };
}

function extractSiteFromBrasilApi_(json) {
  if (json.site) return json.site;
  if (json.website) return json.website;
  return '';
}

function mapMainCnae_(json) {
  if (json.cnae_fiscal_descricao) {
    return `${json.cnae_fiscal || ''} ${json.cnae_fiscal_descricao || ''}`.trim();
  }

  if (Array.isArray(json.cnae_principal) && json.cnae_principal.length) {
    const item = json.cnae_principal[0];
    if (typeof item === 'string') return item;
    return `${item.codigo || ''} ${item.descricao || ''}`.trim();
  }

  if (json.cnae_principal) return String(json.cnae_principal);
  return '';
}

function mapSecondaryCnaes_(json) {
  if (Array.isArray(json.cnaes_secundarios)) {
    return json.cnaes_secundarios.map(item => {
      if (typeof item === 'string') return item;
      return `${item.codigo || ''} ${item.descricao || ''}`.trim();
    }).filter(Boolean);
  }
  return [];
}

function pickPhoneFromCnpjJson_(json) {
  const candidates = [
    json.ddd_telefone_1,
    json.ddd_telefone_2,
    json.telefone
  ].filter(Boolean);

  return uniqueNormalized_(candidates)[0] || '';
}

/************************************************************
 * SITE
 ************************************************************/
function emptyWebsiteData_() {
  return {
    site: '',
    emails: [],
    phones: [],
    whatsapps: [],
    contatoNome: '',
    contatoTelefone: '',
    fonteContato: '',
    fontesSite: [],
    paginasAnalisadas: [],
    bodyText: ''
  };
}

function pickBestSite_(cnpjData) {
  return normalizeUrl_(cnpjData.site || '');
}

function inspectWebsite_(url) {
  const baseUrl = normalizeUrl_(url);
  if (!baseUrl) return emptyWebsiteData_();

  const pages = buildCandidatePages_(baseUrl);

  let allEmails = [];
  let allPhones = [];
  let allWhatsapps = [];
  let allSources = [];
  let analyzedPages = [];
  let bodyText = '';
  let contatoNome = '';
  let contatoTelefone = '';
  let fonteContato = '';

  for (let i = 0; i < pages.length && i < CONFIG.MAX_SITE_PAGES; i++) {
    const pageUrl = pages[i];

    try {
      const html = fetchHtml_(pageUrl);
      if (!html) continue;
      if (!looksLikeHtml_(html)) continue;

      analyzedPages.push(pageUrl);
      allSources.push(pageUrl);

      allEmails = allEmails.concat(extractEmails_(html));
      allPhones = allPhones.concat(extractPhones_(html));
      allWhatsapps = allWhatsapps.concat(extractWhatsApps_(html));

      const publicContact = extractPublicContactFromHtml_(html);
      if (!contatoNome && publicContact.name) {
        contatoNome = publicContact.name;
        contatoTelefone = publicContact.phone || '';
        fonteContato = pageUrl;
      }

      bodyText += ' ' + stripHtml_(html).slice(0, 2500);

      Utilities.sleep(CONFIG.SITE_DELAY_MS);
    } catch (e) {
      // ignora falhas pontuais do site
    }
  }

  return {
    site: baseUrl,
    emails: uniqueNormalized_(allEmails),
    phones: uniquePhones_(allPhones),
    whatsapps: uniqueNormalized_(allWhatsapps),
    contatoNome: contatoNome,
    contatoTelefone: contatoTelefone,
    fonteContato: fonteContato,
    fontesSite: uniqueNormalized_(allSources),
    paginasAnalisadas: uniqueNormalized_(analyzedPages),
    bodyText: bodyText.trim()
  };
}

function buildCandidatePages_(baseUrl) {
  const root = baseUrl.replace(/\/+$/, '');
  return CONFIG.CONTACT_PATHS.map(path => root + path);
}

function fetchHtml_(url) {
  const res = UrlFetchApp.fetch(url, {
    method: 'get',
    muteHttpExceptions: true,
    followRedirects: true,
    headers: {
      'User-Agent': 'Mozilla/5.0'
    }
  });

  const code = res.getResponseCode();
  if (code >= 200 && code < 400) {
    return res.getContentText();
  }
  return '';
}

function looksLikeHtml_(html) {
  const h = String(html || '').toLowerCase();
  return h.indexOf('<html') !== -1 || h.indexOf('<body') !== -1 || h.indexOf('<div') !== -1;
}

