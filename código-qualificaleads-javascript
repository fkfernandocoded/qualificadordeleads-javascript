 * MERGE
 ************************************************************/
function mergeLeadData_(cnpjData, websiteData) {
  const emails = uniqueNormalized_([].concat(cnpjData.email || [], websiteData.emails || []).filter(Boolean));
  const phones = uniquePhones_([].concat(cnpjData.telefone || [], websiteData.phones || []).filter(Boolean));
  const whatsapps = uniqueNormalized_(websiteData.whatsapps || []);

  return {
    razaoSocial: cnpjData.razaoSocial || '',
    nomeFantasia: cnpjData.nomeFantasia || '',
    situacaoCadastral: cnpjData.situacaoCadastral || '',
    cnaePrincipal: cnpjData.cnaePrincipal || '',
    cnaesSecundarios: cnpjData.cnaesSecundarios || [],
    uf: cnpjData.uf || '',
    cidade: cnpjData.cidade || '',
    site: websiteData.site || cnpjData.site || '',
    emails: emails,
    phones: phones,
    whatsapps: whatsapps,
    contatoNome: websiteData.contatoNome || '',
    contatoTelefone: websiteData.contatoTelefone || '',
    fonteContato: websiteData.fonteContato || '',
    fonteCnpj: cnpjData.fonteCnpj || '',
    fontesSite: websiteData.fontesSite || [],
    paginasAnalisadas: websiteData.paginasAnalisadas || [],
    textBlob: [
      cnpjData.razaoSocial,
      cnpjData.nomeFantasia,
      cnpjData.cnaePrincipal,
      (cnpjData.cnaesSecundarios || []).join(' '),
      websiteData.bodyText || ''
    ].join(' ')
  };
}

/************************************************************
 * ANÁLISE DE FIT
 ************************************************************/
function analyzeLeadFit_(lead) {
  const normalizedText = normalizeText_(lead.textBlob);
  const keywordsStrong = findKeywordsInText_(normalizedText, CONFIG.KEYWORDS_STRONG);
  const keywordsMedium = findKeywordsInText_(normalizedText, CONFIG.KEYWORDS_MEDIUM);
  const negativeKeywords = findKeywordsInText_(normalizedText, CONFIG.NEGATIVE_KEYWORDS);

  const cnaeStrong = cnaeMatchesPrefixes_(lead.cnaePrincipal, lead.cnaesSecundarios, CONFIG.CNAE_STRONG_PREFIXES);
  const cnaeMedium = cnaeMatchesPrefixes_(lead.cnaePrincipal, lead.cnaesSecundarios, CONFIG.CNAE_MEDIUM_PREFIXES);

  let score = 0;
  let reasons = [];
  let matchType = 'SEM_MATCH';

  if (cnaeStrong) {
    score += 50;
    reasons.push('CNAE forte aderente');
  }

  if (cnaeMedium) {
    score += 16;
    reasons.push('CNAE potencialmente aderente');
  }

  score += Math.min(keywordsStrong.length * 15, 30);
  if (keywordsStrong.length) {
    reasons.push(`Palavras-chave fortes: ${keywordsStrong.length}`);
  }

  score += Math.min(keywordsMedium.length * 4, 12);
  if (keywordsMedium.length) {
    reasons.push(`Palavras-chave médias: ${keywordsMedium.length}`);
  }

  if (negativeKeywords.length) {
    score -= Math.min(negativeKeywords.length * 10, 25);
    reasons.push('Termos negativos encontrados');
  }

  if (lead.site) score += 3;
  if ((lead.emails || []).length) score += 3;
  if ((lead.phones || []).length) score += 3;
  if ((lead.whatsapps || []).length) score += 4;

  score = Math.max(0, Math.min(score, 100));

  const allKeywords = uniqueNormalized_(keywordsStrong.concat(keywordsMedium));

  if (
    cnaeStrong ||
    (keywordsStrong.length >= 2 && score >= 45) ||
    (cnaeMedium && keywordsStrong.length >= 1 && score >= 40)
  ) {
    matchType = cnaeStrong ? 'CNAE_FORTE' : 'KEYWORD_FORTE';
    return {
      decision: 'APPROVED',
      score: score,
      matchType: matchType,
      reason: reasons.join(' | ') || 'Lead aderente',
      keywordsFound: allKeywords,
      cnaeStrong: cnaeStrong,
      strongKeywordCount: keywordsStrong.length
    };
  }

  if (
    (cnaeMedium && (keywordsMedium.length >= 1 || keywordsStrong.length >= 1)) ||
    (keywordsStrong.length >= 1 && score >= 30) ||
    score >= 32
  ) {
    return {
      decision: 'REVIEW',
      score: score,
      matchType: 'REVISAO',
      reason: reasons.join(' | ') || 'Sinais parciais, revisar manualmente',
      keywordsFound: allKeywords,
      cnaeStrong: cnaeStrong,
      strongKeywordCount: keywordsStrong.length
    };
  }

  return {
    decision: 'REJECT',
    score: score,
    matchType: 'SEM_MATCH',
    reason: reasons.join(' | ') || 'Sem aderência suficiente',
    keywordsFound: allKeywords,
    cnaeStrong: cnaeStrong,
    strongKeywordCount: keywordsStrong.length
  };
}

function cnaeMatchesPrefixes_(mainCnae, secondaryCnaes, prefixes) {
  const text = normalizeText_([mainCnae].concat(secondaryCnaes || []).join(' '))
    .replace(/\s+/g, '');

  return prefixes.some(prefix => text.indexOf(String(prefix).toLowerCase()) !== -1);
}

function findKeywordsInText_(normalizedText, keywords) {
  return keywords.filter(keyword => {
    const k = normalizeText_(keyword);
    return k && normalizedText.indexOf(k) !== -1;
  });
}

/************************************************************
 * EXTRAÇÃO
 ************************************************************/
function extractEmails_(html) {
  const matches = html.match(/[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}/gi) || [];
  return uniqueNormalized_(matches.map(v => v.toLowerCase()).filter(isUsefulEmail_));
}

function extractPhones_(html) {
  const matches = html.match(/(?:\+?55\s?)?(?:\(?\d{2}\)?\s?)?(?:9?\d{4})[-.\s]?\d{4}/g) || [];
  return uniquePhones_(matches.map(v => v.trim()));
}

function extractWhatsApps_(html) {
  const results = [];

  const waLinks = html.match(/https?:\/\/(?:wa\.me|api\.whatsapp\.com|web\.whatsapp\.com)\/[^\s"'<>]+/gi) || [];
  results.push.apply(results, waLinks);

  const genericLinks = html.match(/https?:\/\/[^\s"'<>]*whatsapp[^\s"'<>]*/gi) || [];
  results.push.apply(results, genericLinks);

  const possibleMobiles = html.match(/(?:\+?55\s?)?(?:\(?\d{2}\)?\s?)?(?:9\d{4})[-.\s]?\d{4}/g) || [];
  possibleMobiles.forEach(v => results.push(v.trim()));

  return uniqueNormalized_(results);
}

function extractPublicContactFromHtml_(html) {
  const text = stripHtml_(html);

  const patterns = [
    /(?:respons[aá]vel|comercial|atendimento|diretor|gerente|s[oó]cio|administrador)\s*[:\-]?\s*([A-ZÀ-Ú][A-Za-zÀ-ú' -]{5,60})/i,
    /(?:falar com|contato com)\s*[:\-]?\s*([A-ZÀ-Ú][A-Za-zÀ-ú' -]{5,60})/i
  ];

  let name = '';
  for (let i = 0; i < patterns.length; i++) {
    const m = text.match(patterns[i]);
    if (m && m[1]) {
      name = m[1].trim();
      break;
    }
  }

  const phones = extractPhones_(html);

  return {
    name: name,
    phone: phones[0] || ''
  };
}

function isUsefulEmail_(email) {
  return !/example\.com|dominio\.com|teste@|test@|email@/i.test(email);
}

function stripHtml_(html) {
  return String(html || '')
    .replace(/<script[\s\S]*?<\/script>/gi, ' ')
    .replace(/<style[\s\S]*?<\/style>/gi, ' ')
    .replace(/<noscript[\s\S]*?<\/noscript>/gi, ' ')
    .replace(/<[^>]+>/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

/************************************************************
 * CNPJ
 ************************************************************/
function normalizeCnpj_(value) {
  return String(value || '').replace(/\D/g, '');
}

function isValidCnpj_(cnpj) {
  if (!cnpj || cnpj.length !== 14) return false;
  if (/^(\d)\1+$/.test(cnpj)) return false;

  let length = cnpj.length - 2;
  let numbers = cnpj.substring(0, length);
  let digits = cnpj.substring(length);
  let sum = 0;
  let pos = length - 7;

  for (let i = 0; i < length; i++) {
    sum += Number(numbers.charAt(i)) * pos--;
    if (pos < 2) pos = 9;
  }

  let result = sum % 11 < 2 ? 0 : 11 - (sum % 11);
  if (result !== Number(digits.charAt(0))) return false;

  length += 1;
  numbers = cnpj.substring(0, length);
  sum = 0;
  pos = length - 7;

  for (let i = 0; i < length; i++) {
    sum += Number(numbers.charAt(i)) * pos--;
    if (pos < 2) pos = 9;
  }

  result = sum % 11 < 2 ? 0 : 11 - (sum % 11);
  return result === Number(digits.charAt(1));
}

/************************************************************
 * PLANILHA - UPSERT
 ************************************************************/
function appendOrUpdateApprovedRow_(sheet, result) {
  const rowData = buildApprovedRowData_(result);
  upsertRowByCnpj_(sheet, result.cnpj, rowData, 'APPROVED');
}

function appendOrUpdateReviewRow_(sheet, result) {
  const rowData = buildReviewRowData_(result);
  upsertRowByCnpj_(sheet, result.cnpj, rowData, 'REVIEW');
}

function buildApprovedRowData_(result) {
  return [
    result.rawCnpj,
    result.cnpj,
    result.cnpjValido ? 'SIM' : 'NAO',
    result.razaoSocial || '',
    result.nomeFantasia || '',
    result.situacaoCadastral || '',
    result.cnaePrincipal || '',
    (result.cnaesSecundarios || []).join(' | '),
    result.uf || '',
    result.cidade || '',
    result.site || '',
    (result.emails || []).join(' | '),
    (result.phones || []).join(' | '),
    (result.whatsapps || []).join(' | '),
    result.contatoNome || '',
    result.contatoTelefone || '',
    result.matchType || '',
    result.matchScore || 0,
    result.matchReason || '',
    (result.keywordsFound || []).join(' | '),
    result.fonteCnpj || '',
    (result.fontesSite || []).join(' | '),
    result.fonteContato || '',
    (result.paginasAnalisadas || []).join(' | '),
    new Date()
  ];
}

function buildReviewRowData_(result) {
  return [
    result.rawCnpj,
    result.cnpj,
    result.cnpjValido ? 'SIM' : 'NAO',
    result.razaoSocial || '',
    result.nomeFantasia || '',
    result.situacaoCadastral || '',
    result.cnaePrincipal || '',
    (result.cnaesSecundarios || []).join(' | '),
    result.uf || '',
    result.cidade || '',
    result.site || '',
    (result.emails || []).join(' | '),
    (result.phones || []).join(' | '),
    (result.whatsapps || []).join(' | '),
    result.matchScore || 0,
    result.reviewReason || '',
    (result.keywordsFound || []).join(' | '),
    result.fonteCnpj || '',
    (result.fontesSite || []).join(' | '),
    (result.paginasAnalisadas || []).join(' | '),
    new Date()
  ];
}

function upsertRowByCnpj_(sheet, cnpj, rowData, sheetType) {
  const rowIndex = findRowByCnpj_(sheet, cnpj);

  if (rowIndex) {
    const existingRow = sheet.getRange(rowIndex, 1, 1, rowData.length).getValues()[0];
    const mergedRow = mergeRowData_(existingRow, rowData, sheetType);
    sheet.getRange(rowIndex, 1, 1, mergedRow.length).setValues([mergedRow]);
  } else {
    sheet.appendRow(rowData);
  }
}

function findRowByCnpj_(sheet, cnpj) {
  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return 0;

  const values = sheet.getRange(2, 1, lastRow - 1, 2).getValues();
  for (let i = 0; i < values.length; i++) {
    const existingCnpj = normalizeCnpj_(values[i][1] || values[i][0] || '');
    if (existingCnpj && existingCnpj === cnpj) {
      return i + 2;
    }
  }

  return 0;
}

function mergeRowData_(existingRow, newRow, sheetType) {
  const merged = [];

  for (let i = 0; i < newRow.length; i++) {
    const oldVal = existingRow[i];
    const newVal = newRow[i];

    if (i === newRow.length - 1) {
      merged.push(new Date());
      continue;
    }

    if (isPipeFieldIndex_(i, sheetType)) {
      merged.push(mergePipeSeparated_(oldVal, newVal));
      continue;
    }

    if (sheetType === 'APPROVED' && i === 17) {
      merged.push(Math.max(Number(oldVal || 0), Number(newVal || 0)));
      continue;
    }

    if (sheetType === 'REVIEW' && i === 14) {
      merged.push(Math.max(Number(oldVal || 0), Number(newVal || 0)));
      continue;
    }

    merged.push(pickBestValue_(oldVal, newVal));
  }

  return merged;
}

function isPipeFieldIndex_(index, sheetType) {
  if (sheetType === 'APPROVED') {
    return [7, 11, 12, 13, 19, 21, 23].indexOf(index) !== -1;
  }

  if (sheetType === 'REVIEW') {
    return [7, 11, 12, 13, 16, 18, 19].indexOf(index) !== -1;
  }

  return false;
}

function pickBestValue_(oldVal, newVal) {
  const oldStr = String(oldVal || '').trim();
  const newStr = String(newVal || '').trim();

  if (!oldStr && newStr) return newVal;
  if (oldStr && !newStr) return oldVal;

  if (String(newVal || '').length > String(oldVal || '').length) return newVal;
  return oldVal;
}

function mergePipeSeparated_(oldVal, newVal) {
  const oldArr = String(oldVal || '')
    .split('|')
    .map(v => normalizePipeValue_(v))
    .filter(Boolean);

  const newArr = String(newVal || '')
    .split('|')
    .map(v => normalizePipeValue_(v))
    .filter(Boolean);

  return uniqueNormalized_(oldArr.concat(newArr)).join(' | ');
}

function normalizePipeValue_(value) {
  return String(value || '').replace(/\s+/g, ' ').trim();
}

function getProcessedCnpjs_(sheets) {
  const map = {};

  sheets.forEach(sheet => {
    const lastRow = sheet.getLastRow();
    if (lastRow < 2) return;

    const values = sheet.getRange(2, 1, lastRow - 1, 2).getValues();
    for (let i = 0; i < values.length; i++) {
      const cnpj = normalizeCnpj_(values[i][1] || values[i][0] || '');
      if (cnpj) map[cnpj] = true;
    }
  });

  return map;
}

function removerDuplicadosLeadsAprovados() {
  removeDuplicatesFromSheet_(CONFIG.APPROVED_SHEET, 'APPROVED');
}

function removerDuplicadosRevisaoManual() {
  removeDuplicatesFromSheet_(CONFIG.REVIEW_SHEET, 'REVIEW');
}

function removeDuplicatesFromSheet_(sheetName, sheetType) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(sheetName);
  if (!sheet) return;

  const data = sheet.getDataRange().getValues();
  if (data.length < 2) return;

  const header = data[0];
  const byCnpj = {};
  const order = [];

  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const cnpj = normalizeCnpj_(row[1] || row[0] || '');
    if (!cnpj) continue;

    if (!byCnpj[cnpj]) {
      byCnpj[cnpj] = row;
      order.push(cnpj);
    } else {
      byCnpj[cnpj] = mergeRowData_(byCnpj[cnpj], row, sheetType);
    }
  }

  const newData = [header].concat(order.map(cnpj => byCnpj[cnpj]));

  sheet.clearContents();
  sheet.clearFormats();
  sheet.getRange(1, 1, newData.length, newData[0].length).setValues(newData);
  sheet.setFrozenRows(1);
  formatHeader_(sheet, newData[0].length);
}

function logRow_(cnpj, status, detail) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CONFIG.LOG_SHEET);
  sheet.appendRow([new Date(), cnpj, status, String(detail || '').slice(0, 500)]);
}

function getOrCreateSheet_(ss, name, headers) {
  let sheet = ss.getSheetByName(name);
  if (!sheet) {
    sheet = ss.insertSheet(name);
  }

  if (sheet.getLastRow() === 0) {
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    sheet.setFrozenRows(1);
    formatHeader_(sheet, headers.length);
  }

  return sheet;
}

function resetSheet_(ss, name, headers) {
  let sheet = ss.getSheetByName(name);
  if (!sheet) {
    sheet = ss.insertSheet(name);
  }
  sheet.clearContents();
  sheet.clearFormats();
  sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
  sheet.setFrozenRows(1);
  formatHeader_(sheet, headers.length);
}

function formatHeader_(sheet, colCount) {
  sheet.getRange(1, 1, 1, colCount)
    .setFontWeight('bold')
    .setBackground('#d9ead3')
    .setWrap(true);

  sheet.autoResizeColumns(1, colCount);
}

/************************************************************
 * UTILITÁRIOS
 ************************************************************/
function normalizeText_(text) {
  return String(text || '')
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

function normalizeUrl_(url) {
  let u = String(url || '').trim();
  if (!u) return '';

  if (!/^https?:\/\//i.test(u)) {
    u = 'https://' + u;
  }

  return u.replace(/\s/g, '');
}

function unique_(arr) {
  const seen = {};
  return (arr || []).filter(item => {
    const key = String(item || '').trim();
    if (!key || seen[key]) return false;
    seen[key] = true;
    return true;
  });
}

function uniqueNormalized_(arr) {
  const seen = {};
  const result = [];

  (arr || []).forEach(item => {
    const original = String(item || '').replace(/\s+/g, ' ').trim();
    const key = normalizeText_(original);
    if (!original || !key || seen[key]) return;
    seen[key] = true;
    result.push(original);
  });

  return result;
}

function uniquePhones_(arr) {
  const seen = {};
  const result = [];

  (arr || []).forEach(item => {
    const original = String(item || '').trim();
    const key = original.replace(/\D/g, '');
    if (!original || !key || key.length < 8 || seen[key]) return;
    seen[key] = true;
    result.push(original);
  });

  return result;
}

function safeErrorMessage_(e) {
  try {
    return String(e && e.message ? e.message : e);
  } catch (_) {
    return 'Erro desconhecido';
  }
}
